# =============================================================================
# TRM PLATFORM - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# APP CONFIGURATION
# =============================================================================
APP_NAME=TRM Platform
APP_VERSION=0.1.0
DEBUG=True

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trm_platform
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# IMPORTANT: Generate a secure random string for production!
# Example: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-use-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_HOURS=24
JWT_ABSOLUTE_TIMEOUT_HOURS=24

# Password hashing (bcrypt rounds)
PASSWORD_HASH_ROUNDS=12

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
SESSION_TIMEOUT_MINUTES=480  # 8 hours
SESSION_ABSOLUTE_TIMEOUT_MINUTES=1440  # 24 hours

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_LOGIN=5/hour
RATE_LIMIT_API=100/minute
RATE_LIMIT_AI_CHAT=10/5minutes

# =============================================================================
# AI SERVICES - OPENAI
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# =============================================================================
# VECTOR DATABASE - PINECONE
# =============================================================================
# Get your API key from: https://www.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=trm-knowledge-base

# =============================================================================
# FILE STORAGE - AWS S3
# =============================================================================
# Optional: For CV uploads and file storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=trm-platform-uploads
AWS_REGION=us-east-1

# CV Upload Settings
MAX_CV_FILE_SIZE_MB=5
ALLOWED_CV_EXTENSIONS=.pdf,.docx,.doc

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
# For sending emails (password resets, notifications, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@trmplatform.com

# =============================================================================
# FRONTEND & CORS
# =============================================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# MONITORING & LOGGING (Optional)
# =============================================================================
# Sentry DSN for error tracking
# SENTRY_DSN=your-sentry-dsn-here

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# DEPLOYMENT (Production Only)
# =============================================================================
# Set to False in production!
# DEBUG=False

# Production database (use connection pooling service like PgBouncer)
# DATABASE_URL=postgresql+asyncpg://user:password@production-db:5432/trm_platform

# Production JWT secret (generate with: openssl rand -hex 32)
# JWT_SECRET_KEY=production-secret-key-min-64-chars-long

# Production CORS origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
